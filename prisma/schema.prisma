// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Plakar Events models

model CompanyProfile {
  id                   String   @id @default(cuid())
  companyName          String
  description          String
  productsJson         Json     @default("[]")
  personasJson         Json     @default("[]")
  messagingJson        Json     @default("[]")
  positioningText      String   @default("")
  regionsJson          Json     @default("[]")
  competitorsJson      Json     @default("[]")
  cplTargetsJson       Json     @default("{}")
  budgetRangesJson     Json     @default("{}")
  leadEstimatesJson    Json     @default("{}")
  avgDealValue         Float    @default(0)
  leadToOppRate        Float    @default(0)
  overheadPerEventJson Json     @default("{}")
  calendarName         String   @default("Plakar Events")
  updatedAt            DateTime @updatedAt
}

model Event {
  id                   String             @id @default(cuid())
  name                 String
  url                  String             @unique
  organizer            String             @default("unknown")
  startDate            DateTime?
  endDate              DateTime?
  city                 String             @default("unknown")
  country              String             @default("unknown")
  region               String             @default("unknown")
  description          String             @default("")
  topicsJson           Json               @default("[]")
  eventType            String             @default("conference") // conference | meetup | analyst | community
  attendanceEstimate   Int?
  sponsorshipCost      Float?
  sponsorshipInfoText  String             @default("unknown")
  cfpDeadline          DateTime?
  cfpInfoText          String             @default("unknown")
  source               String             @default("web") // luma | web
  lastRefreshedAt      DateTime           @default(now())
  createdAt            DateTime           @default(now())
  score                EventScore?
  roi                  EventROI?
  competitorSignals    CompetitorSignal[]
  strategy             EventStrategy?
  planningStatus       PlanningStatus?
}

model EventScore {
  id                   String   @id @default(cuid())
  eventId              String   @unique
  event                Event    @relation(fields: [eventId], references: [id])
  audienceMatch        Float    @default(0)
  topicRelevance       Float    @default(0)
  strategicAlignment   Float    @default(0)
  budgetFit            Float    @default(0)
  competitorSignal     Float    @default(0)
  sentiment            Float    @default(0)
  totalScore           Float    @default(0)
  scoreExplanationJson Json     @default("{}")
  confidence           String   @default("low") // high | medium | low
  updatedAt            DateTime @updatedAt
}

model EventROI {
  id                    String   @id @default(cuid())
  eventId               String   @unique
  event                 Event    @relation(fields: [eventId], references: [id])
  estimatedCost         Float?
  estimatedLeads        Int?
  cplLow                Float?
  cplHigh               Float?
  estimatedPipeline     Float?
  roiMultiplier         Float?
  roiLabel              String   @default("Unknown") // Strong | Moderate | Weak | Unknown
  calculationInputsJson Json     @default("{}")
  userOverridesJson     Json     @default("{}")
  updatedAt             DateTime @updatedAt
}

model CompetitorSignal {
  id             String   @id @default(cuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id])
  competitorName String
  sponsorStatus  String   @default("unknown") // yes | no | unknown
  sponsorTier    String   @default("unknown")
  evidenceText   String   @default("")
  confidence     String   @default("low")
  updatedAt      DateTime @updatedAt
}

model EventStrategy {
  id                   String   @id @default(cuid())
  eventId              String   @unique
  event                Event    @relation(fields: [eventId], references: [id])
  recommendationType   String   @default("Attend") // Sponsor | Speak | Attend | Pass
  recommendationReason String   @default("")
  messagingJson        Json     @default("[]")
  talkingPointsText    String   @default("")
  staffingText         String   @default("")
  sideEventsText           String   @default("")
  partnerOpportunitiesText String   @default("")
  cfpAnglesJson            Json     @default("[]")
  cfpDraftText         String   @default("")
  generatedAt          DateTime @default(now())
}

model PlanningStatus {
  id          String   @id @default(cuid())
  eventId     String   @unique
  event       Event    @relation(fields: [eventId], references: [id])
  status      String   @default("candidate") // candidate | shortlisted | approved | rejected
  owner       String   @default("")
  notes       String   @default("")
  gcalEventId String?
  updatedAt   DateTime @updatedAt
}
